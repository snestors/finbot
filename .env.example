# Database (SQLite, ruta relativa al proyecto)
DB_PATH=data/finbot.db

# Gemini
GOOGLE_AI_API_KEY=AIzaSy...

# Server
PORT=8080
TIMEZONE=America/Lima

# WhatsApp
WHATSAPP_MY_NUMBER=51xxxxxxxxx@c.us
